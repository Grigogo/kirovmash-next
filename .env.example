# Postgres (docker-compose)
POSTGRES_USER=conveyor
POSTGRES_PASSWORD=conveyor_pass
POSTGRES_DB=conveyor_db
POSTGRES_PORT=5432

# Prisma / Next.js
DATABASE_URL="postgresql://conveyor:conveyor_pass@localhost:5432/conveyor_db"

# Public site base URL (used for SEO metadata, sitemap, OG tags)
NEXT_PUBLIC_BASE_URL=https://kirovmash.ru

# Auth.js (сгенерировать: npx auth secret)
AUTH_SECRET=
